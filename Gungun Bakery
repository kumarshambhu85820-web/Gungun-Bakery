<!DOCTYPE html><html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Gungun Bakery | Premium Experience</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@500;700&family=Poppins:wght@300;400;500&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/ScrollTrigger.min.js"></script><style>
:root{
--cream:#FFF5E1;
--brown:#4E342E;
--pink:#F8BBD0;
--gold:#D4AF37;
}

*{margin:0;padding:0;box-sizing:border-box;}
body{font-family:Poppins,sans-serif;background:var(--cream);color:var(--brown);overflow-x:hidden;}
h1,h2,h3{font-family:'Playfair Display',serif;}

nav{
position:fixed;width:100%;top:0;display:flex;justify-content:space-between;
padding:15px 30px;background:rgba(255,245,225,0.85);
backdrop-filter:blur(12px);z-index:1000;
}
nav a{text-decoration:none;color:var(--brown);margin:0 10px;transition:.3s;}
nav a:hover{color:var(--gold);}

.hero{
height:100vh;background:url('https://images.unsplash.com/photo-1559622214-17d7c1a4e5e0') center/cover;
display:flex;align-items:center;justify-content:center;text-align:center;color:white;
}
.hero h1{font-size:3.5rem;}
.hero p{margin:10px 0;}

.btn{
padding:12px 25px;border:none;background:var(--gold);color:white;
cursor:pointer;margin:5px;border-radius:30px;transition:.4s;
}
.btn:hover{transform:scale(1.08);box-shadow:0 10px 30px rgba(0,0,0,0.3);}

section{padding:90px 20px;}

.cards{display:grid;grid-template-columns:repeat(auto-fit,minmax(250px,1fr));gap:25px;}
.card{
background:white;border-radius:20px;overflow:hidden;transition:.4s;position:relative;
}
.card img{width:100%;height:220px;object-fit:cover;transition:.5s;}
.card:hover img{transform:scale(1.1);} 
.card:hover{transform:translateY(-10px);box-shadow:0 15px 40px rgba(0,0,0,0.2);} 

.price{color:var(--gold);font-weight:bold;}

.filter-btns{text-align:center;margin-bottom:30px;}
.filter-btns button{margin:5px;}

.form{
max-width:500px;margin:auto;padding:25px;border-radius:20px;
background:rgba(255,255,255,0.25);backdrop-filter:blur(20px);
box-shadow:0 10px 40px rgba(0,0,0,0.1);
}
.form input,.form textarea{
width:100%;margin:10px 0;padding:12px;border:none;border-radius:10px;
}

.gallery{column-count:3;column-gap:15px;}
.gallery img{width:100%;margin-bottom:15px;border-radius:10px;transition:.4s;cursor:pointer;}
.gallery img:hover{transform:scale(1.05);} 

footer{text-align:center;padding:30px;background:var(--brown);color:white;}

.whatsapp-float{
position:fixed;bottom:20px;right:20px;background:#25D366;color:white;
padding:15px;border-radius:50%;font-size:22px;z-index:1000;
animation:pulse 1.5s infinite;
}

@keyframes pulse{
0%{box-shadow:0 0 0 0 rgba(37,211,102,0.7);} 
70%{box-shadow:0 0 0 15px rgba(37,211,102,0);} 
100%{box-shadow:0 0 0 0 rgba(37,211,102,0);} 
}

</style></head>
<body><nav>
<h3>Gungun Bakery</h3>
<div>
<a href="#">Home</a>
<a href="#products">Products</a>
<a href="#order">Order</a>
<a href="#gallery">Gallery</a>
<a href="#contact">Contact</a>
</div>
</nav><section class="hero">
<div>
<h1>Delight in Every Bite</h1>
<p>Luxury Cakes & Fast Food in Dalsingh Sarai</p>
<a href="https://wa.me/919296343002?text=I%20want%20to%20order"><button class="btn">Order Now</button></a>
</div>
</section><section id="products">
<h2 style="text-align:center">Our Menu</h2>
<div class="filter-btns">
<button class="btn" onclick="filter('all')">All</button>
<button class="btn" onclick="filter('cake')">Cake</button>
<button class="btn" onclick="filter('fast')">Fast Food</button>
</div><div class="cards">
<div class="card cake"><img src="https://images.unsplash.com/photo-1605478371310-a9f1e96b7d77"><div style="padding:15px"><h3>Cake 🎂</h3><p class="price">₹300 - ₹1500</p></div></div>
<div class="card fast"><img src="https://images.unsplash.com/photo-1601924582975-7d3a3f0b0c3c"><div style="padding:15px"><h3>Pizza 🍕</h3><p class="price">₹120 - ₹250</p></div></div>
<div class="card fast"><img src="https://images.unsplash.com/photo-1550547660-d9450f859349"><div style="padding:15px"><h3>Burger 🍔</h3><p class="price">₹60 - ₹120</p></div></div>
<div class="card cake"><img src="https://images.unsplash.com/photo-1599785209707-a456fc1337bb"><div style="padding:15px"><h3>Pastry 🍰</h3><p class="price">₹40 - ₹80</p></div></div>
<div class="card fast"><img src="https://images.unsplash.com/photo-1546069901-eacef0df6022"><div style="padding:15px"><h3>Sandwich 🥪</h3><p class="price">₹70 - ₹150</p></div></div>
<div class="card fast"><img src="https://images.unsplash.com/photo-1604908177522-0404f53c7d57"><div style="padding:15px"><h3>Momos 😊</h3><p class="price">₹60 - ₹120</p></div></div>
</div>
</section><section id="order">
<h2 style="text-align:center">Custom Cake Order</h2>
<div class="form">
<input placeholder="Name">
<input placeholder="Phone">
<input placeholder="Flavor">
<input placeholder="Size">
<textarea placeholder="Message"></textarea>
<a href="https://wa.me/919296343002"><button class="btn">Order via WhatsApp</button></a>
</div>
</section><section id="gallery">
<h2 style="text-align:center">Gallery</h2>
<div class="gallery">
<img src="https://images.unsplash.com/photo-1603532648955-039310d9ed75">
<img src="https://images.unsplash.com/photo-1541976076758-347942db197c">
<img src="https://images.unsplash.com/photo-1604908176997-431dc5c30c0f">
</div>
</section><section id="contact">
<h2 style="text-align:center">Contact</h2>
<p style="text-align:center">IB Road, Near RB College, Dalsingh Sarai</p>
<p style="text-align:center">📞 +91 92963 43002 / +91 72941 43002</p>
<p style="text-align:center">⏰ 9:00 AM – 10:00 PM</p>
<div style="text-align:center;margin-top:10px;">
<a href="https://maps.app.goo.gl/s2xzyukpRzH95wer7"><button class="btn">View Map</button></a>
</div>
</section><a href="https://wa.me/919296343002" class="whatsapp-float">💬</a>

<footer>
<p>© 2026 Gungun Bakery | Premium Experience</p>
</footer><script>
// FILTER
function filter(type){
let cards=document.querySelectorAll('.card');
cards.forEach(card=>{
if(type==='all'){card.style.display='block';}
else{card.classList.contains(type)?card.style.display='block':card.style.display='none';}
});
}

// GSAP ANIMATION
gsap.from('.hero h1',{y:50,opacity:0,duration:1});
gsap.from('.card',{scrollTrigger:'.card',y:80,opacity:0,stagger:0.2});
</script></body>
</html>
